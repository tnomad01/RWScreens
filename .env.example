# ── Data Provider ─────────────────────────────────────────────────────────────
# Switch between providers by changing DATA_PROVIDER.
# Only the credentials for the active provider need to be filled in.
DATA_PROVIDER=alpaca       # alpaca | polygon

# ── Alpaca Markets (free tier available) ──────────────────────────────────────
# Sign up at https://alpaca.markets → Paper Trading → API Keys
ALPACA_API_KEY=your_alpaca_key_id_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# ── Polygon.io (paid plans for WebSocket + full data) ─────────────────────────
# Sign up at https://polygon.io → Dashboard → API Keys
POLYGON_API_KEY=your_polygon_api_key_here

# ── Trade Ideas DB seed (optional) ───────────────────────────────────────────
# Absolute path to the stock-screening-mvp SQLite DB.
# When set, scanner seeding uses real pre-market gappers from the scraper
# instead of the hardcoded watchlist fallback.
# TRADE_IDEAS_DB_PATH=/home/mwa/Claude/stock-screening-mvp/data/stock_screen.db

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
